{
  "name": "bizyaml-vscode",
  "displayName": "BizYAML",
  "description": "Enterprise-grade DX for BizYAML with LSP support",
  "version": "1.0.4",
  "publisher": "antonylu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antonylu0826/BizYAML.git"
  },
  "files": [
    "client/dist",
    "server/dist",
    "icon.png",
    "LICENSE",
    "language-configuration.json",
    "package.json",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "bizyaml",
    "dsl",
    "erp",
    "crud",
    "lsp",
    "validation"
  ],
  "main": "./client/dist/extension.js",
  "activationEvents": [
    "*",
    "onLanguage:yaml",
    "onLanguage:bizyaml",
    "onFile:**/*.entity.yaml",
    "onFile:**/*.flow.yaml",
    "onFile:**/*.views.yaml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yaml",
        "extensions": [
          ".entity.yaml",
          ".flow.yaml",
          ".views.yaml"
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "BizYAML",
      "properties": {
        "bizyaml.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the BizYAML language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:client && npm run compile:server",
    "compile:client": "esbuild client/src/extension.ts --bundle --outfile=client/dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile:server": "esbuild server/src/server.ts --bundle --outfile=server/dist/server.js --format=cjs --platform=node",
    "watch": "npm run watch:client & npm run watch:server",
    "watch:client": "npm run compile:client -- --watch",
    "watch:server": "npm run compile:server -- --watch",
    "publish:marketplace": "vsce publish --packagePath bizyaml-vscode-1.0.4.vsix",
    "publish:openvsx": "ovsx publish bizyaml-vscode-1.0.4.vsix",
    "bundle": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.2"
  },
  "dependencies": {
    "@bizyaml/parser": "*",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  }
}
